{
  "name": "payplug/payplug-woocommerce",
  "description": "",
  "version": "2.17.2",
  "license": "GPL-3.0-or-later",
  "type": "wordpress-plugin",
  "keywords": [
    "payplug",
    "woocommerce",
    "gateway"
  ],
  "authors": [
    {
      "name": "PayPlug",
      "email": "support@payplug.com"
    },
    {
      "name": "Be API",
      "email": "technical@beapi.fr"
    }
  ],
  "require": {
    "php": ">=5.6.0",
    "composer/installers": "^1.9",
    "payplug/payplug-php": "^4.0.0"
  },
  "require-dev": {
    "captainhook/captainhook": "^5.14",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "php-stubs/woocommerce-stubs": "^10.6",
    "phpdocumentor/phpdocumentor": "3.*",
    "bamarni/composer-bin-plugin": "^1.4",
    "automattic/jetpack-changelogger": "3.0.2",
    "squizlabs/php_codesniffer": "*",
    "phpcompatibility/php-compatibility": "*",
    "phpunit/phpunit": "^8.5",
    "yoast/phpunit-polyfills": "^3.0",
    "mockery/mockery": "^1.3",
    "wp-phpunit/wp-phpunit": "^6.7",
    "friendsofphp/php-cs-fixer": "^3.4",
    "phpstan/phpstan": "^1.12"
  },
  "autoload": {
    "psr-4": {
      "Payplug\\PayplugWoocommerce\\": "src",
      "libphonenumber\\": "lib/libphonenumber"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Payplug\\PayplugWoocommerce\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "bamarni/composer-bin-plugin": true,
      "symfony/flex": true
    }
  },
  "scripts": {
    "post-install-cmd": "vendor/bin/captainhook install --force --skip-existing",
    "post-update-cmd": "vendor/bin/captainhook install --force --skip-existing",
    "stan": "vendor/bin/phpstan analyse --configuration=phpstan.dist.neon --memory-limit=512M",
    "cs-lint": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff",
    "cs-fix": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php"
  }
}
